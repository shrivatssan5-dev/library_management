PORT=3001

# Local development (individual fields)
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=library
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your-password
DATABASE_SSL=false

# Vercel / cloud (use one approach — DATABASE_URL is preferred on Vercel)
# DATABASE_URL=postgresql://user:password@host.region.provider.com:5432/library?sslmode=require
# DATABASE_SSL=true

JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=8h
