PORT=3001

# Supabase Session pooler (IPv4) — Supabase → Connect → Session pooler
DATABASE_HOST=aws-1-ap-southeast-1.pooler.supabase.com
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USERNAME=postgres.YOUR_PROJECT_REF
DATABASE_PASSWORD=your-supabase-password
DATABASE_SSL=true

JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=8h

# Frontend URLs for CORS (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:5173,https://library-management-flame-nu.vercel.app
STUDENT_APP_URL=http://localhost:5174
ALLOWED_ORIGINS=
